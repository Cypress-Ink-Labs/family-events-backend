# ── Supabase (required; auto-injected in deployed functions, needed locally) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM provider (required for tagging / enrichment / review) ──
# Generic OpenAI-compatible provider (e.g. Ollama). See supabase/docs/LOCAL_LLM_TAGGING.md
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
# OpenAI (used by embeddings + review when configured; takes precedence over AI_* when set)
OPENAI_API_KEY=
OPENAI_MODEL=
# optional: number of events processed per LLM-review batch (default varies per function)
LLM_REVIEW_BATCH_SIZE=
# optional: max number of due source records fetched per run
DUE_SOURCE_LIMIT=

# ── Email (Resend) ──
# required: Resend API key
RESEND_API_KEY=re_your-api-key
# optional: sender address (default: "Family Events <onboarding@resend.dev>")
RESEND_FROM=Family Events <onboarding@resend.dev>
# optional: reply-to address
RESEND_REPLY_TO=
# optional: admin email for system notifications
ADMIN_NOTIFY_EMAIL=
# required: shared secret validating the Supabase email hook payload
SEND_EMAIL_HOOK_SECRET=

# ── Telegram ──
# optional: Telegram Bot API token (from @BotFather); required for digest_telegram delivery
TELEGRAM_BOT_TOKEN=

# ── Web Push (VAPID) ──
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# required: mailto: or https: URI identifying the push sender
VAPID_SUBJECT=

# ── Apple Push Notifications (APNs) ──
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=
# optional: "development" or "production" (default: "production")
APNS_ENVIRONMENT=

# ── Firebase Cloud Messaging ──
# required for Android push: JSON service account credentials
FCM_SERVICE_ACCOUNT_JSON=

# ── Stock image providers (optional; tried in fallback order) ──
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# ── Weather ──
# optional: OpenWeatherMap API key for weather enrichment
OPENWEATHER_API_KEY=

# ── Observability (optional) ──
SENTRY_DSN=
# optional: float 0–1 fraction of transactions to trace (default: 0)
SENTRY_TRACES_SAMPLE_RATE=

# ── App / CORS ──
# optional: public app URL used in email links (default: https://family-events.up.railway.app)
APP_URL=https://family-events.up.railway.app
# optional: comma-separated extra origins for CORS allowlist
ALLOWED_ORIGINS=

# ── Infra / packages ──
# required: Railway API token for deploy/cron management
RAILWAY_TOKEN=your-railway-token
# required: GitHub PAT (read:packages) for consuming @family-events/* npm packages
NODE_AUTH_TOKEN=ghp_your-pat
