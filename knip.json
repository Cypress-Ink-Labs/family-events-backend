{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "include": ["files", "dependencies", "unlisted", "binaries"],
  "ignoreBinaries": ["terraform", "supabase", "deno", "psql"],
  "ignoreWorkspaces": ["packages/config-quality", "packages/config-typescript"],
  "ignoreIssues": {
    "supabase/functions/**/*.ts": ["unlisted"]
  },
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.mjs", "scripts/**/*.ts", "tests/**/*.mjs", "tests/**/*.ts"],
      "project": ["scripts/**/*.mjs", "scripts/**/*.ts", "tests/**/*.mjs", "tests/**/*.ts"]
    },
    "packages/contracts": {
      "entry": ["src/index.ts!", "src/database.types.ts!"],
      "project": ["src/**/*.ts!"],
      "ignoreDependencies": [
        "@cypress-ink-labs/config-quality",
        "@cypress-ink-labs/config-typescript"
      ]
    },
    "packages/deploy-cli": {
      "entry": ["src/cli.ts!"],
      "project": ["src/**/*.ts!", "tests/**/*.ts"],
      "ignoreDependencies": [
        "@cypress-ink-labs/config-quality",
        "@cypress-ink-labs/config-typescript"
      ]
    },
    "packages/email": {
      "entry": ["src/index.ts!", "emails/**/*.tsx!", "scripts/**/*.tsx!"],
      "project": ["src/**/*.ts!", "emails/**/*.tsx!", "scripts/**/*.tsx!"],
      "react-email": false,
      "ignoreDependencies": ["@cypress-ink-labs/config-typescript"]
    },
    "supabase/functions": {
      "entry": ["**/*.ts"],
      "project": ["**/*.ts"]
    }
  }
}
