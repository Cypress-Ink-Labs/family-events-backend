{
  "cron-tag-queue": {
    "config_path": ".railway/railway.ts",
    "source_repo": "Cypress-Ink-Labs/family-events-backend",
    "root_directory": "cron/tag-queue",
    "builder": "DOCKERFILE",
    "dockerfile_path": "Dockerfile",
    "cron_schedule": "*/5 * * * *",
    "restart_policy_type": "NEVER",
    "required_latest_deployment_status": "SUCCESS",
    "forbidden_instance_statuses": ["CRASHED", "FAILED"],
    "required_env": [
      "SUPABASE_SERVICE_ROLE_KEY",
      "IS_CRON_ENABLED_URL",
      "LOG_CRON_RUN_URL",
      "PROCESS_TAG_QUEUE_URL"
    ]
  },
