public-hoist-pattern[]=oxfmt
public-hoist-pattern[]=oxlint
public-hoist-pattern[]=vitest
public-hoist-pattern[]=tsc
public-hoist-pattern[]=typescript

# GitHub Packages registry for @cypress-ink-labs scoped packages.
# Set NODE_AUTH_TOKEN to a classic PAT with read:packages (or write:packages for publish).
@cypress-ink-labs:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
