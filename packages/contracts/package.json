{
  "name": "@cypress-ink-labs/contracts",
  "version": "0.0.3",
  "description": "TypeScript types generated from the family-events Supabase schema.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cypress-Ink-Labs/family-events-backend.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./database-types": "./src/database.types.ts"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "format": "oxfmt --config ../config-quality/oxfmt.base.json --write src",
    "format:check": "oxfmt --config ../config-quality/oxfmt.base.json --check src",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@cypress-ink-labs/config-quality": "workspace:*",
    "@cypress-ink-labs/config-typescript": "workspace:*"
  }
}
