{
  "name": "@cypress-ink-labs/email",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "deploy": "tsx scripts/deploy-templates.tsx",
    "check": "tsc -p tsconfig.json --noEmit",
    "format": "oxfmt --config ../config-quality/oxfmt.base.json --write src emails scripts",
    "format:check": "oxfmt --config ../config-quality/oxfmt.base.json --check src emails scripts"
  },
  "dependencies": {
    "@react-email/render": "^2.0.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.0",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@cypress-ink-labs/config-typescript": "workspace:*",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.22.4"
  }
}
