{
  "name": "@cypress-ink-labs/deploy-cli",
  "version": "0.0.1",
  "private": true,
  "bin": {
    "family-events-deploy": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "cli": "tsx src/cli.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json --noEmit",
    "format": "oxfmt --config ../../packages/config-quality/oxfmt.base.json --write src tests",
    "format:check": "oxfmt --config ../../packages/config-quality/oxfmt.base.json --check src tests"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "ora": "^9.4.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "oxfmt": "^0.55.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vitest": "4.1.9"
  }
}
